{
	"name": "trackdex-obsidian",
	"version": "0.0.1",
	"description": "Read-only catalog of GPX tracks for Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node scripts/build.mjs",
		"build": "tsc -noEmit -skipLibCheck && node scripts/build.mjs production",
		"test": "node --test",
		"deploy": "node scripts/deploy.mjs",
		"deploy:dev": "node scripts/deploy.mjs dev",
		"version": "node scripts/version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"leaflet": "^1.9.4",
		"obsidian": "latest"
	}
}
